<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Withdraw Invoice</title>
  <style>
    body {
      font-family: 'Segoe UI', Arial, sans-serif;
      background-color: #f5f7fb;
      margin: 0;
      padding: 0;
    }

    .invoice-container {
      max-width: 600px;
      margin: 40px auto;
      background: #fff;
      border-radius: 12px;
      box-shadow: 0 6px 20px rgba(0, 0, 0, 0.08);
      overflow: hidden;
    }

    .invoice-header {
      background: linear-gradient(135deg, #007bff, #0056d2);
      color: #fff;
      padding: 24px;
      text-align: center;
    }

    .invoice-header h1 {
      margin: 0;
      font-size: 24px;
      letter-spacing: 0.5px;
    }

    .invoice-body {
      padding: 30px 24px;
      color: #333;
    }

    .invoice-body p {
      margin: 10px 0;
      font-size: 15px;
    }

    .invoice-body strong {
      color: #000;
    }

    .amount-box {
      margin-top: 20px;
      background: #f0f4ff;
      border-left: 4px solid #007bff;
      padding: 15px 20px;
      border-radius: 8px;
    }

    .amount-box p {
      font-size: 16px;
      margin: 0;
      font-weight: 600;
    }


    .success-msg {
      margin-top: 25px;
      text-align: center;
      color: #28a745;
      font-weight: 500;
      font-size: 15px;
    }
  </style>
</head>

<body>
  <div class="invoice-container">
    <div class="invoice-header">
      <h1>Order Invoice</h1>
    </div>

    <div class="invoice-body">
      <p><strong>Payment ID:</strong>
        <%= transactionId  %>
      </p>
      <p><strong>Customer Name:</strong>
        <%= customerName %>
      </p>
      <p><strong>Payment Method:</strong>
        <%= paymentMethod %>
      </p>
      <p><strong>Date:</strong>
        <%= OrderDate %>
      </p>

      <div class="amount-box">
        <p>Total Amount Paid: <%= totalAmount %>
        </p>
      </div>

      <p class="success-msg">
        ✅ Your Order has been processed successfully.
        Thank you for being a valuable Customer!
      </p>
    </div>
  </div>
</body>

</html>